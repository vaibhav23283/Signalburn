# Arohan Backend Configuration
# Copy this file to .env and update with your values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=arohan_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000

# Model Configuration (Dual Mode)
# Set to "true" to use fine-tuned Ollama model, "false" to use Groq API
USE_LOCAL_MODEL=false

# Ollama Configuration (only used when USE_LOCAL_MODEL=true)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=arohan-medical

# Groq API Configuration (only used when USE_LOCAL_MODEL=false)
GROQ_API_KEY=your_groq_api_key_here

# Security
JWT_SECRET=your_jwt_secret_here
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number